{
  "name": "obsidian-integration-testing",
  "version": "8.0.1",
  "description": "Simplifies integration testing of Obsidian plugins.",
  "keywords": [
    "obsidian",
    "testing",
    "integration",
    "vitest"
  ],
  "homepage": "https://github.com/mnaoumov/obsidian-integration-testing#readme",
  "bugs": {
    "url": "https://github.com/mnaoumov/obsidian-integration-testing/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnaoumov/obsidian-integration-testing.git"
  },
  "license": "MIT",
  "author": "Michael Naumov",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib/esm/index.d.mts",
        "default": "./dist/lib/esm/index.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/index.d.cts",
        "default": "./dist/lib/cjs/index.cjs"
      }
    },
    "./jest-global-setup": {
      "import": {
        "types": "./dist/lib/esm/jest/global-setup.d.mts",
        "default": "./dist/lib/esm/jest/global-setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/jest/global-setup.d.cts",
        "default": "./dist/lib/cjs/jest/global-setup.cjs"
      }
    },
    "./jest-global-teardown": {
      "import": {
        "types": "./dist/lib/esm/jest/global-teardown.d.mts",
        "default": "./dist/lib/esm/jest/global-teardown.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/jest/global-teardown.d.cts",
        "default": "./dist/lib/cjs/jest/global-teardown.cjs"
      }
    },
    "./jest-setup": {
      "import": {
        "types": "./dist/lib/esm/jest/setup.d.mts",
        "default": "./dist/lib/esm/jest/setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/jest/setup.d.cts",
        "default": "./dist/lib/cjs/jest/setup.cjs"
      }
    },
    "./vitest-global-setup": {
      "import": {
        "types": "./dist/lib/esm/vitest/global-setup.d.mts",
        "default": "./dist/lib/esm/vitest/global-setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/vitest/global-setup.d.cts",
        "default": "./dist/lib/cjs/vitest/global-setup.cjs"
      }
    },
    "./vitest-setup": {
      "import": {
        "types": "./dist/lib/esm/vitest/setup.d.mts",
        "default": "./dist/lib/esm/vitest/setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/vitest/setup.d.cts",
        "default": "./dist/lib/cjs/vitest/setup.cjs"
      }
    },
    "./vitest/typings": {
      "import": {
        "types": "./dist/lib/esm/vitest/typings.d.mts"
      },
      "require": {
        "types": "./dist/lib/cjs/vitest/typings.d.cts"
      }
    }
  },
  "main": "dist/lib/cjs/index.cjs",
  "module": "dist/lib/esm/index.mjs",
  "types": "dist/lib/esm/index.d.mts",
  "bin": {
    "obsidian-integration-testing": "bin/obsidian-integration-testing.mjs"
  },
  "files": [
    "!dist/*.tgz",
    "**/package.json",
    "bin/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "jiti scripts/build.ts",
    "build:clean": "jiti scripts/build-clean.ts",
    "build:compile": "jiti scripts/build-compile.ts",
    "build:compile:typescript": "jiti scripts/build-compile-typescript.ts",
    "build:lib": "jiti scripts/build-lib.ts",
    "build:types": "jiti scripts/build-types.ts",
    "commit": "jiti scripts/commit.ts",
    "format": "jiti scripts/format.ts",
    "format:check": "jiti scripts/format-check.ts",
    "lint": "jiti scripts/lint.ts",
    "lint:fix": "jiti scripts/lint-fix.ts",
    "lint:md": "jiti scripts/lint-md.ts",
    "lint:md:fix": "jiti scripts/lint-md-fix.ts",
    "prepare": "jiti scripts/prepare.ts",
    "spellcheck": "jiti scripts/spellcheck.ts",
    "test": "jiti scripts/test.ts",
    "test:coverage": "jiti scripts/test-coverage.ts",
    "test:integration": "jiti scripts/test-integration.ts",
    "test:jest": "jiti scripts/test-jest.ts",
    "test:watch": "jiti scripts/test-watch.ts",
    "version": "jiti scripts/version.ts"
  },
  "overrides": {
    "@sinonjs/fake-timers": "13.0.5",
    "electron": "42.0.1",
    "eslint-plugin-import": "$eslint-plugin-import-x",
    "js-yaml": "^4.2.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "markdown-it": "^14.2.0",
    "mermaid": "11.15.0",
    "tmp": "0.2.5",
    "type-fest": "$type-fest",
    "typescript": "$typescript",
    "urlpattern-polyfill": "npm:dry-uninstall",
    "vite": "$vite"
  },
  "dependencies": {
    "puppeteer-core": "^25.3.0",
    "webdriverio": "9.27.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.1",
    "@obsidian-typings/obsidian-public-latest": "^6.22.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/semver": "^7.7.1",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/rule-tester": "^8.63.0",
    "@typescript-eslint/utils": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/runner": "4.1.0",
    "@wdio/protocols": "9.27.0",
    "@wdio/types": "9.27.0",
    "better-typescript-lib": "^2.12.0",
    "cspell": "^10.0.1",
    "czg": "^1.13.1",
    "dprint": "^0.55.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-config": "^30.4.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "linkinator": "^7.6.1",
    "markdownlint": "^0.41.0",
    "markdownlint-cli2": "^0.23.0",
    "markdownlint-rule-relative-links": "^5.1.1",
    "nano-staged": "^1.0.2",
    "obsidian": "^1.13.1",
    "semver": "^7.8.5",
    "ts-jest": "^29.4.11",
    "type-fest": "^5.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "obsidian": "^1.12.3",
    "type-fest": "^5.6.0"
  }
}
